import("//base/hiviewdfx/hiview/hiview.gni")
import("//build/config/features.gni")
import("//build/test.gni")

ohos_fuzztest("SanitizerTelemetryOnEventFuzzTest") {
  module_out_path = "hiview/hiview/faultlogger"

  fuzz_config_file = "//base/hiviewdfx/hiview/plugins/faultlogger/test/common/fuzztest/sanitizertelemetryonevent_fuzzer"

  include_dirs = [
    ".",
    "../common/include",
    "$hiview_core",
    "$hiview_faultlogger/service/bdfr_base/",
    "$hiview_faultlogger/service/bdfr_base/sanitizer_collector",
    "$hiview_faultlogger/service/bdfr_base/public_include",
  ]

  configs = [
    "$hiview_faultlogger/service/bdfr_base:bdfr_base_local_include",
    "$hiview_faultlogger/service/bdfr_base:bdfr_base_public_include",
    "$hiview_faultlogger/service:bdfr_public_include",
  ]

  defines = [
    "UNIT_TEST",
    "UNITTEST",
  ]

  cflags = [
    "-Dprivate=public",
    "-Dprotected=public",
  ]
  cflags_cc = [ "-DUNITTEST" ]

  sources = [
    "sanitizertelemetryonevent_fuzzer.cpp",
    "$hiview_faultlogger/service/bdfr_base/sanitizer_collector/sanitizer_telemetry.cpp",
  ]

  deps = [
    "$hiview_base:hiviewbase_static_lib_for_tdd",
    "$hiview_core:hiview_core_for_test",
  ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "c_utils:utils",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "init:libbegetutil",
  ]

  resource_config_file =
      "$hiview_faultlogger/test/common/resource/ohos_test.xml"
}

group("fuzztest") {
  testonly = true
  deps = [ ":SanitizerTelemetryOnEventFuzzTest" ]
}
