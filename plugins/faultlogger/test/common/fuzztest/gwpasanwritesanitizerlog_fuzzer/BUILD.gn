import("//base/hiviewdfx/hiview/hiview.gni")
import("//build/config/features.gni")
import("//build/test.gni")

ohos_fuzztest("GwpAsanWriteSanitizerLogFuzzTest") {
  module_out_path = "hiview/hiview/faultlogger"

  fuzz_config_file = "//base/hiviewdfx/hiview/plugins/faultlogger/test/common/fuzztest/gwpasanwritesanitizerlog_fuzzer"

  include_dirs = [
    ".",
    "../common/include",
    "$hiview_core",
    "$hiview_faultlogger/service/bdfr_base/sanitizer_collector/gwp_asan",
  ]

  defines = [
    "UNIT_TEST",
    "UNITTEST",
  ]

  cflags = [
    "-Dprivate=public",
    "-Dprotected=public",
  ]
  cflags_cc = [ "-DUNITTEST" ]

  sources = [
    "gwpasanwritesanitizerlog_fuzzer.cpp",
  ]

  deps = [
    "$hiview_base:hiviewbase_static_lib_for_tdd",
    "$hiview_faultlogger/service/bdfr_base/sanitizer_collector/gwp_asan:libasan_logger",
  ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "faultloggerd:libfaultloggerd",
    "hilog:libhilog",
    "hisysevent:libhisysevent_easy",
    "init:libbegetutil",
    "openssl:libcrypto_shared",
  ]

  resource_config_file =
      "$hiview_faultlogger/test/common/resource/ohos_test.xml"
}

group("fuzztest") {
  testonly = true
  deps = [ ":GwpAsanWriteSanitizerLogFuzzTest" ]
}
