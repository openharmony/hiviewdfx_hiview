import("//base/hiviewdfx/hiview/hiretrieval/hiretrieval.gni")
import("//build/test.gni")

module_output_path = "hiretrieval/native/"

group("unittest") {
  testonly = true
  deps = [
    ":HiRetrievalDynamicLoaderUnitTest",
    ":HiRetrievalMgrUnitTest",
  ]
}

config("hiretrieval_unittest_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "unittest/common",
    "$hiretrieval_frameworks/include",
  ]

  cflags = []
}

ohos_unittest("HiRetrievalDynamicLoaderUnitTest") {
  module_out_path = module_output_path

  configs = [ ":hiretrieval_unittest_config" ]

  sources = [ "unittest/common/hiretrieval_dynamic_loader_unit_test.cpp" ]

  deps = [ "$hiretrieval_frameworks:libhiretrieval" ]

  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "googletest:gtest_main",
  ]
}

ohos_unittest("HiRetrievalMgrUnitTest") {
  module_out_path = module_output_path

  configs = [ ":hiretrieval_unittest_config" ]

  sources = [ "unittest/common/hiretrieval_mgr_unit_test.cpp" ]

  deps = [ "$hiretrieval_frameworks:libhiretrieval" ]

  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "googletest:gtest_main",
  ]
}
