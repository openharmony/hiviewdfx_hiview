import("//base/hiviewdfx/hiview/hiretrieval/hiretrieval.gni")
import("//build/ohos.gni")

config("hiretrieval_napi_config") {
  visibility = [ "*:*" ]

  include_dirs = [ "include" ]
}

ohos_shared_library("libhiretrieval_napi") {
  branch_protector_ret = "pac_ret"

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    cfi_vcall_icall_only = true
    debug = false
  }

  configs = [ ":hiretrieval_napi_config" ]

  public_configs = [ ":hiretrieval_napi_config" ]

  sources = [
    "src/hiretrieval_napi.cpp",
    "src/hiretrieval_napi_util.cpp",
  ]

  deps = [
    "$hiretrieval_frameworks:libhiretrieval",
    "$hiretrieval_interfaces/common:hiretrieval_common_set",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "napi:ace_napi",
  ]

  relative_install_dir = "module/hiviewdfx"

  part_name = "hiview"

  subsystem_name = "hiviewdfx"
}
